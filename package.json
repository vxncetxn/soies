{
  "name": "soies",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "check": "pnpm fmt:check && pnpm typecheck && pnpm lint && pnpm healthcheck:rc && pnpm test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "healthcheck:rc": "react-compiler-healthcheck",
    "ios": "expo run:ios",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:rc": "oxlint -A all -D react/react-compiler --react-plugin src",
    "start": "expo start",
    "test": "node --no-warnings --experimental-strip-types --experimental-sqlite --experimental-loader ./tests/typescript-loader.mjs --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@expo/ui": "~57.0.7",
    "@marceloterreiro/flash-calendar": "^2.0.0",
    "@op-engineering/op-sqlite": "^17.1.1",
    "@shopify/flash-list": "2.0.2",
    "@swmansion/react-native-bottom-sheet": "^0.16.1",
    "babel-plugin-react-compiler": "1.0.0",
    "expo": "~57.0.7",
    "expo-application": "~57.0.2",
    "expo-asset": "~57.0.6",
    "expo-blur": "~57.0.2",
    "expo-build-properties": "~57.0.6",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-local-authentication": "~57.0.1",
    "expo-localization": "~57.0.1",
    "expo-media-library": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-screen-capture": "~57.0.1",
    "expo-screen-orientation": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-widgets": "~57.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-ease": "0.7.3",
    "react-native-edge-fade": "^0.0.1",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-nano-icons": "^0.1.8",
    "react-native-nitro-image": "^0.15.1",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-pager-view": "8.0.2",
    "react-native-pulsar": "^1.6.1",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-share": "^12.3.1",
    "react-native-signature-ink": "file:vendor/react-native-signature-ink",
    "react-native-teleport": "^1.1.9",
    "react-native-view-shot": "5.1.0",
    "react-native-vision-camera": "^5.0.11",
    "react-native-worklets": "^0.10.0",
    "tailwindcss": "~4.1.16",
    "uniwind": "~1.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~57.0.3",
    "oxfmt": "^0.53.0",
    "oxlint": "1.73.0",
    "react-compiler-healthcheck": "1.0.0",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@9.7.1",
  "pnpm": {
    "patchedDependencies": {
      "metro@0.84.4": "patches/metro@0.84.4.patch",
      "metro-runtime@0.84.4": "patches/metro-runtime@0.84.4.patch"
    }
  },
  "expo": {
    "autolinking": {
      "ios": {
        "buildFromSource": [
          "react-native-reanimated",
          "react-native-worklets"
        ]
      }
    }
  },
  "op-sqlite": {
    "performanceMode": true,
    "fts5": true
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": true,
      "IOS_SYNCHRONOUSLY_UPDATE_UI_PROPS": true
    }
  }
}
