{
  "expo": {
    "scheme": "soies",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/ABCStefan-Simple-Trial.otf",
            "./assets/fonts/Geist-Medium.otf",
            "./assets/fonts/Geist-Regular.otf",
            "./assets/fonts/GeistMono-Regular.otf"
          ]
        }
      ],
      [
        "react-native-nano-icons",
        {
          "iconSets": [
            {
              "inputDir": "./assets/icons"
            }
          ]
        }
      ],
      "expo-image",
      "expo-asset",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.vance.soies.widgetextension",
          "groupIdentifier": "group.com.vance.soies",
          "enableAndroid": false,
          "widgets": [
            {
              "name": "FeaturedArtefactWidget",
              "displayName": "Featured Artefact",
              "description": "Keep a Soies artefact on your Home Screen.",
              "supportedFamilies": ["systemLarge"],
              "contentMarginsDisabled": true,
              "ios": {
                "supportedFamilies": ["systemLarge"],
                "contentMarginsDisabled": true,
                "configuration": {
                  "title": "Featured Artefact",
                  "description": "Choose which featured artefact this widget displays.",
                  "parameters": {
                    "featuredSlot": {
                      "title": "Featured Artefact",
                      "type": "enum",
                      "values": [
                        {
                          "name": "Featured Artefact 1",
                          "value": "slot1"
                        },
                        {
                          "name": "Featured Artefact 2",
                          "value": "slot2"
                        },
                        {
                          "name": "Featured Artefact 3",
                          "value": "slot3"
                        },
                        {
                          "name": "Featured Artefact 4",
                          "value": "slot4"
                        },
                        {
                          "name": "Featured Artefact 5",
                          "value": "slot5"
                        }
                      ],
                      "default": "slot1"
                    }
                  }
                }
              },
              "android": null
            }
          ]
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": false,
          "cameraPermission": "Allow soies to use the camera to create Print entries.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Allow soies to save shared artefacts to your photo library.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": []
        }
      ],
      [
        "react-native-share",
        {
          "ios": ["fb", "facebook-stories", "instagram", "instagram-stories"],
          "android": ["com.facebook.katana", "com.instagram.android"]
        }
      ],
      "expo-build-properties"
    ],
    "name": "soies",
    "slug": "soies",
    "ios": {
      "bundleIdentifier": "com.vance.soies",
      "deploymentTarget": "17.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow soies to use the camera to create Print entries.",
        "NSPhotoLibraryAddUsageDescription": "Allow soies to save shared artefacts to your photo library.",
        "LSApplicationQueriesSchemes": ["fb", "facebook-stories", "instagram", "instagram-stories"],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb5ae819-ea64-467e-ad0a-7d2994693e16"
      }
    },
    "android": {
      "package": "com.vance.soies",
      "permissions": ["android.permission.CAMERA"],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "experiments": {
      "reactCompiler": true
    }
  }
}
