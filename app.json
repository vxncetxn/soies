{
  "expo": {
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/ABCStefan-Simple-Trial.otf",
            "./assets/fonts/Geist-Medium.otf",
            "./assets/fonts/Geist-Regular.otf",
            "./assets/fonts/GeistMono-Regular.otf"
          ]
        }
      ],
      [
        "react-native-nano-icons",
        {
          "iconSets": [
            {
              "inputDir": "./assets/icons"
            }
          ]
        }
      ],
      "expo-image",
      "expo-asset",
      "expo-widgets",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow soies to access your photos to create Print entries.",
          "cameraPermission": "Allow soies to use the camera to create Print entries.",
          "microphonePermission": false
        }
      ]
    ],
    "name": "soies",
    "slug": "soies",
    "ios": {
      "bundleIdentifier": "com.anonymous.soies",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow soies to use the camera to create Print entries.",
        "NSPhotoLibraryUsageDescription": "Allow soies to access your photos to create Print entries.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb5ae819-ea64-467e-ad0a-7d2994693e16"
      }
    },
    "android": {
      "package": "com.anonymous.soies",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "experiments": {
      "reactCompiler": true
    }
  }
}
